                    <div class="idx-co-logo co-a">A</div>
                    <span class="idx-co-name-primary">Ashford Group</span>
                  </div>
                </td>
                <td class="idx-td signals">
                  <div class="idx-td-signals">
                    <span class="signal-tag signal-tag--geo">Funding</span>
                    <span class="signal-tag signal-tag--hiring">Hiring surge</span>
                    <span class="signal-tag signal-tag--research">Research intent</span>
                  </div>
                </td>
                <td class="idx-td">
                  <div class="idx-owner"><div class="idx-av av-blue">D</div><span>Dana Fitzgerald</span></div>
                </td>
                <td class="idx-td muted">Feb 02, 2024 08:02 AM EST</td>
                <td class="idx-td muted">404-551-2298</td>
                <td class="idx-td muted">Atlanta, GA</td>
                <td class="idx-td muted">Real Estate</td>
              </tr>

            </tbody>
          </table>
        </div>

        <!-- Footer -->
        <div class="idx-footer">
          <div class="idx-footer-actions">
            <button class="idx-footer-btn" title="Refresh">
              <svg width="16" height="16" viewBox="0 0 32 32" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M4.83008 17.0098C5.37007 16.9098 5.89024 17.2703 5.99023 17.8203C6.84037 22.5901 10.9802 26.0498 15.8301 26.0498H16C21.1181 26.0498 23.9832 22.9367 25.251 21.0498H19.9707C19.4207 21.0498 18.9707 20.5998 18.9707 20.0498C18.9708 19.4999 19.4208 19.0498 19.9707 19.0498H26.9365C27.0687 19.0452 27.2028 19.067 27.332 19.1191C27.7043 19.265 27.9706 19.6274 27.9707 20.0498V27.0498C27.9707 27.5996 27.5205 28.0495 26.9707 28.0498C26.4207 28.0498 25.9707 27.5998 25.9707 27.0498V23.3994C24.1701 25.5384 20.9922 28.0498 15.9902 28.0498H15.8301C10.0101 28.0498 5.04051 23.8999 4.02051 18.1699C3.92051 17.6299 4.28008 17.1098 4.83008 17.0098Z"/><path d="M16.1602 4C21.98 4.0001 26.9497 8.15003 27.9697 13.8799C28.0697 14.4198 27.71 14.9399 27.1602 15.04C27.1002 15.05 27.0395 15.0596 26.9795 15.0596L26.9697 15.0498C26.49 15.0497 26.0704 14.7101 25.9902 14.2305C25.1403 9.46062 21.0002 6.00021 16.1504 6H15.9795C10.8616 6.00018 7.99622 9.11321 6.72852 11H12C12.55 11 13 11.45 13 12C13 12.55 12.55 13 12 13H5.05273C5.00247 13.0022 4.95195 13.0008 4.90137 12.9951C4.87794 12.9928 4.85497 12.9883 4.83203 12.9844C4.82426 12.9829 4.81636 12.9821 4.80859 12.9805C4.34942 12.8904 4 12.4845 4 12V5C4 4.45 4.45 4 5 4C5.55 4 6 4.45 6 5V8.65918C7.79918 6.51812 10.9807 4 15.9902 4H16.1602Z"/></svg>
            </button>
            <button class="idx-footer-btn" title="Undo">
              <svg width="16" height="16" viewBox="0 0 32 32" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M13 6C6.93 6.00026 2 10.9302 2 17V23C2 23.5498 2.45 23.9997 3 24C3.55 24 4 23.55 4 23V17C4 12.0402 8.04 8.00026 13 8C17.96 8 22 12.04 22 17V21.5791L17.7202 17.2998C17.3302 16.9099 16.7001 16.91 16.31 17.2998C15.92 17.6898 15.92 18.32 16.31 18.71L22.2114 24.6104C22.375 24.821 22.6193 24.9666 22.8979 24.9951L23 25H23.02C23.0164 25 23.0128 24.9991 23.0093 24.999C23.0561 24.9986 23.1019 24.994 23.147 24.9873C23.1948 24.9802 23.2422 24.971 23.2886 24.957C23.3049 24.9521 23.3204 24.9452 23.3364 24.9395C23.4714 24.8912 23.5984 24.8154 23.7095 24.71L29.7095 18.71C30.0995 18.32 30.0995 17.6898 29.7095 17.2998C29.3195 16.9102 28.6902 16.9102 28.3003 17.2998L24 21.6006V17C24 10.93 19.07 6 13 6Z"/></svg>
            </button>
            <button class="idx-footer-btn" title="Redo">
              <svg width="16" height="16" viewBox="0 0 32 32" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M19.0005 6C25.0703 6.00026 30.0005 10.9302 30.0005 17V23C30.0005 23.5498 29.5503 23.9997 29.0005 24C28.4505 24 28.0005 23.55 28.0005 23V17C28.0005 12.0402 23.9603 8.00026 19.0005 8C14.0405 8 10.0005 12.04 10.0005 17V21.5791L14.2798 17.2998C14.6698 16.9099 15.2999 16.91 15.69 17.2998C16.08 17.6898 16.08 18.32 15.69 18.71L9.78859 24.6104C9.62496 24.821 9.38067 24.9666 9.10207 24.9951L9.00051 25H8.98C8.98356 25 8.98719 24.9991 8.99074 24.999C8.94394 24.9986 8.89815 24.994 8.85305 24.9873C8.80518 24.9802 8.75781 24.971 8.71145 24.957C8.69513 24.9521 8.67955 24.9452 8.66359 24.9395C8.52858 24.8912 8.4016 24.8154 8.29055 24.71L2.29055 18.71C1.90055 18.32 1.90055 17.6898 2.29055 17.2998C2.68048 16.9102 3.30982 16.9102 3.69973 17.2998L8.00051 21.6006V17C8.00051 10.93 12.9305 6 19.0005 6Z"/></svg>
            </button>
            <button class="idx-footer-btn" title="More">
              <svg width="16" height="16" viewBox="0 0 32 32" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M8 14C9.10457 14 10 14.8954 10 16C10 17.1046 9.10457 18 8 18C6.89543 18 6 17.1046 6 16C6 14.8954 6.89543 14 8 14Z"/><path d="M16 14C17.1046 14 18 14.8954 18 16C18 17.1046 17.1046 18 16 18C14.8954 18 14 17.1046 14 16C14 14.8954 14.8954 14 16 14Z"/><path d="M24 14C25.1046 14 26 14.8954 26 16C26 17.1046 25.1046 18 24 18C22.8954 18 22 17.1046 22 16C22 14.8954 22.8954 14 24 14Z"/></svg>
            </button>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<script>
  function showTableForView(viewId) {
    document.querySelectorAll('.idx-table-wrap').forEach(w => {
      w.dataset.hidden = (w.dataset.viewId === viewId) ? 'false' : 'true';
    });
  }
  document.querySelectorAll('.idx-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.idx-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      showTableForView(tab.dataset.view || 'default');
    });
  });
  showTableForView('default');

  (function () {
    const overflowBtn  = document.getElementById('indexOverflowBtn');
    const overflowMenu = document.getElementById('indexOverflowMenu');
    const menuItems    = overflowMenu.querySelectorAll('.idx-actions-menu-item');

    const intentSignals = [
      { id: 'smart-1', text: 'Actively researching CRM vendors on G2' },
      { id: 'smart-2', text: 'Company headcount grew 18% this quarter' },
      { id: 'smart-3', text: 'Searching "Salesforce alternatives" this week' },
      { id: 'smart-4', text: 'New compliance initiative announced publicly' },
      { id: 'smart-5', text: 'Budget cycle starts next month — Q1 signal' },
    ];
    const remainingSignals = [
      'Visited competitor pricing page twice',
      'Job posting signals budget for new tools',
      'Subscribed to industry newsletter last week',
      'Filed 2 support tickets with current vendor',
      'Company expanding to new market — APAC',
      'Attended product demo webinar 4 days ago',
      'Researching integrations on G2 this week',
      'Legal team reviewed DPA documents',
      'Mentioned vendor switch in LinkedIn post',
      '3 team members from same domain visiting',
      'Company raised Series A last quarter',
      'Posted job for RevOps Manager role',
      'Competitor contract expires next month',
      'Board deck included growth target keywords',
      'Active on community forum for CRM tools',
    ];

    let agentTimers = [];
    function clearAgentTimers() {
      agentTimers.forEach(t => clearTimeout(t));
      agentTimers = [];
    }
    function dismissOffer() {
      const offer = document.getElementById('enrich-offer');
      const wrapper = document.getElementById('enrich-offer-wrapper');
      if (offer) offer.classList.remove('shown');
      setTimeout(() => wrapper && wrapper.remove(), 350);
    }
    function resetAgentState() {
      clearAgentTimers();
      const th = document.getElementById('th-smart');
      if (th) th.classList.remove('generating');
      document.querySelectorAll('.col-smart').forEach(el => el.classList.remove('visible'));
      document.querySelectorAll('.smart-cell-content').forEach(el => {
        el.replaceChildren();
        el.classList.remove('shown');
        el.removeAttribute('data-overflow');
        el.style.removeProperty('--ticker-shift');
      });
      const wrapper = document.getElementById('enrich-offer-wrapper');
      if (wrapper) wrapper.remove();
    }
    function setSmartCellText(cell, text) {
      const span = document.createElement('span');
      span.className = 'ticker';
      span.textContent = text;
      cell.replaceChildren(span);
      cell.classList.add('shown');
      requestAnimationFrame(() => {
        const overflow = span.scrollWidth - cell.clientWidth;
        if (overflow > 0) {
          cell.dataset.overflow = 'true';
          cell.style.setProperty('--ticker-shift', `-${overflow + 12}px`);
        }
      });
    }
    function showEnrichOffer() {
      const anchorDiv = document.getElementById('smart-enrich-cell');
      const anchor = anchorDiv ? anchorDiv.closest('td') : null;
      const wrap = document.querySelector('.idx-table-wrap[data-view-id="default"]');
      if (!anchor || !wrap) return;
      const aRect = anchor.getBoundingClientRect();
      const wRect = wrap.getBoundingClientRect();
      const top   = aRect.top  - wRect.top  + wrap.scrollTop;
      const left  = aRect.left - wRect.left + wrap.scrollLeft;
      const wrapper = document.createElement('div');
      wrapper.id = 'enrich-offer-wrapper';
      wrapper.style.cssText = `top:${top}px;left:${left}px;width:${aRect.width}px;padding:6px 12px;`;
      const remaining = document.querySelectorAll('.smart-cell-content').length - intentSignals.length;
      wrapper.innerHTML = `
        <div class="enrich-offer" id="enrich-offer">
          <div class="enrich-offer-top">
            <div class="enrich-offer-icon">
              <svg width="14" height="14" viewBox="0 0 15.47 16" fill="none"><path d="M15 7.514C11.296 7.514 8.203 4.317 8.203.486 8.203.221 7.989 0 7.733 0 7.477 0 7.264.221 7.264.486 7.264 4.317 4.171 7.514.469 7.514.208 7.514 0 7.735 0 8c0 .271.208.486.469.486C4.171 8.486 7.264 11.683 7.264 15.514c0 .265.213.486.469.486.256 0 .469-.221.469-.486C7.264 11.683 10.357 8.486 14.06 8.486 14.318 8.486 14.526 8.265 14.526 8c0-.271-.208-.486-.469-.486Z" fill="#cc3a00"/></svg>
            </div>
            <div class="enrich-offer-body">
              <div class="enrich-offer-title">Enrich ${remaining} more records</div>
              <div class="enrich-offer-sub">Data Agent will analyze intent signals for the remaining contacts in this view.</div>
              <div class="enrich-offer-credit">
                <svg width="9" height="9" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="#cc3a00" stroke-width="1.3" fill="none"/><path d="M7 4v3l2 1.5" stroke="#cc3a00" stroke-width="1.2" stroke-linecap="round" fill="none"/></svg>
                50 Credits
              </div>
            </div>
          </div>
          <div class="enrich-offer-actions">
            <button class="btn-enrich" id="btn-enrich-now">Enrich now</button>
            <button class="btn-enrich-ghost" id="btn-enrich-later">Not now</button>
          </div>
        </div>`;
      wrap.appendChild(wrapper);
      requestAnimationFrame(() => requestAnimationFrame(() => {
        const o = document.getElementById('enrich-offer');
        if (o) o.classList.add('shown');
      }));
      document.getElementById('btn-enrich-now').addEventListener('click', doEnrich);
      document.getElementById('btn-enrich-later').addEventListener('click', dismissOffer);
    }
    function doEnrich() {
      dismissOffer();
      const th = document.getElementById('th-smart');
      if (th) th.classList.add('generating');
      const allCells = document.querySelectorAll('.smart-cell-content');
      remainingSignals.forEach((text, i) => {
        const cell = allCells[intentSignals.length + i];
        if (!cell) return;
        const t = setTimeout(() => {
          setSmartCellText(cell, text);
          if (i === remainingSignals.length - 1 && th) th.classList.remove('generating');
        }, i * 120);
        agentTimers.push(t);
      });
    }
    function startAgentFlow() {
      resetAgentState();
      const th = document.getElementById('th-smart');
      const t0 = setTimeout(() => {
        document.querySelectorAll('.col-smart').forEach(el => el.classList.add('visible'));
        const t1 = setTimeout(() => {
          if (th) th.classList.add('generating');
          intentSignals.forEach(({ id, text }, i) => {
            const t = setTimeout(() => {
              const cell = document.getElementById(id);
              if (cell) setSmartCellText(cell, text);
              if (i === intentSignals.length - 1) {
                if (th) th.classList.remove('generating');
                const t2 = setTimeout(showEnrichOffer, 500);
                agentTimers.push(t2);
              }
            }, i * 400);
            agentTimers.push(t);
          });
        }, 200);
        agentTimers.push(t1);
      }, 800);
      agentTimers.push(t0);
    }

    function setMode(mode) {
      document.body.dataset.prospectMode = mode;
      menuItems.forEach(it => it.classList.toggle('active', it.dataset.prospectMode === mode));
      if (mode === 'carousel') {
        const recTab = document.querySelector('.idx-tab--recommended');
        if (recTab && recTab.classList.contains('active')) {
          document.querySelectorAll('.idx-tab').forEach(t => t.classList.remove('active'));
          const firstTab = document.querySelector('.idx-tab[data-view="default"]');
          if (firstTab) firstTab.classList.add('active');
          showTableForView('default');
        }
      }
      if (mode === 'agent') {
        const recTab = document.querySelector('.idx-tab--recommended');
        if (recTab && recTab.classList.contains('active')) {
          document.querySelectorAll('.idx-tab').forEach(t => t.classList.remove('active'));
          const firstTab = document.querySelector('.idx-tab[data-view="default"]');
          if (firstTab) firstTab.classList.add('active');
          showTableForView('default');
        }
        startAgentFlow();
      } else {
        resetAgentState();
      }
    }

    function closeMenu() {
      overflowMenu.classList.remove('open');
      overflowMenu.setAttribute('aria-hidden', 'true');
      overflowBtn.setAttribute('aria-expanded', 'false');
    }

    function positionMenu() {
      const r = overflowBtn.getBoundingClientRect();
      overflowMenu.style.left = r.left + 'px';
      overflowMenu.style.top = (r.bottom + 6) + 'px';
    }
    overflowBtn.addEventListener('click', e => {
      e.stopPropagation();
      const willOpen = !overflowMenu.classList.contains('open');
      if (willOpen) positionMenu();
      overflowMenu.classList.toggle('open', willOpen);
      overflowMenu.setAttribute('aria-hidden', willOpen ? 'false' : 'true');
      overflowBtn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
      if (willOpen) {
        setTimeout(() => document.addEventListener('click', closeMenu, { once: true }), 0);
      }
    });
    overflowMenu.addEventListener('click', e => e.stopPropagation());
    menuItems.forEach(item => {
      item.addEventListener('click', () => {
        setMode(item.dataset.prospectMode);
        closeMenu();
      });
    });

    setMode('carousel');
  })();

  document.querySelectorAll('.idx-view-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.getAttribute('data-view-target');
      if (target && !btn.classList.contains('active')) {
        window.location.href = target;
        return;
      }
      document.querySelectorAll('.idx-view-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  const checkSvg = '<svg width="10" height="10" viewBox="0 0 14 14" fill="none"><path d="M2 7.5L5.5 11l6.5-7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>';
  document.querySelectorAll('.idx-cb').forEach(cb => {
    cb.addEventListener('click', e => {
      e.stopPropagation();
      cb.classList.toggle('checked');
      cb.innerHTML = cb.classList.contains('checked') ? checkSvg : '';
    });
  });

  (function () {
    var currentMode = 'default';
    var previousMode = 'default';
    var customSettings = { pageHeader: true };
    var menuOpen = false;

    var layoutBtn     = document.getElementById('layoutBtn');
    var layoutMenu    = document.getElementById('layoutMenu');
    var layoutControl = document.getElementById('layoutControl');
    var customPanel   = document.getElementById('layoutCustomPanel');
    var togglePageHdr = document.querySelector('[data-toggle="pageHeader"]');
    var breadcrumbRow = document.querySelector('.idx-breadcrumb-row');
    var tableWrap     = document.querySelector('.idx-table-wrap');
    var menuItems     = {
      default : document.getElementById('layoutOptDefault'),
      focused : document.getElementById('layoutOptFocused'),
      custom  : document.getElementById('layoutOptCustom')
    };

    function setHeaderVisible(visible) {
      breadcrumbRow.classList.toggle('layout-collapsed', !visible);
    }

    function applyMode(mode) {
      currentMode = mode;
      Object.keys(menuItems).forEach(function (k) {
        menuItems[k].classList.toggle('active', k === mode);
      });
      customPanel.classList.toggle('open', mode === 'custom');
      if (mode === 'default')       setHeaderVisible(true);
      else if (mode === 'focused')  setHeaderVisible(false);
      else if (mode === 'custom')   setHeaderVisible(customSettings.pageHeader);
      layoutBtn.classList.toggle('active', mode !== 'default');
    }

    function openMenu() {
      menuOpen = true;
      layoutMenu.classList.add('open');
      layoutMenu.setAttribute('aria-hidden', 'false');
      layoutBtn.setAttribute('aria-expanded', 'true');
      layoutBtn.classList.add('active');
    }

    function closeMenu() {
      menuOpen = false;
      layoutMenu.classList.remove('open');
      layoutMenu.setAttribute('aria-hidden', 'true');
      layoutBtn.setAttribute('aria-expanded', 'false');
      if (currentMode === 'default') layoutBtn.classList.remove('active');
    }

    layoutBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      menuOpen ? closeMenu() : openMenu();
    });

    menuItems.default.addEventListener('click', function () { applyMode('default'); closeMenu(); });
    menuItems.focused.addEventListener('click', function () { applyMode('focused'); closeMenu(); });
    menuItems.custom.addEventListener('click',  function () { applyMode('custom'); });

    togglePageHdr.addEventListener('click', function () {
      var newVal = togglePageHdr.getAttribute('aria-checked') !== 'true';
      togglePageHdr.setAttribute('aria-checked', String(newVal));
      customSettings.pageHeader = newVal;
      if (currentMode === 'custom') setHeaderVisible(newVal);
    });

    document.addEventListener('click', function (e) {
      if (menuOpen && !layoutControl.contains(e.target)) closeMenu();
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && menuOpen) { closeMenu(); layoutBtn.focus(); }
      var tag = document.activeElement ? document.activeElement.tagName : '';
      if (tag === 'INPUT' || tag === 'TEXTAREA' || e.ctrlKey || e.metaKey || e.altKey) return;
      if (e.key === 'f' || e.key === 'F') {
        if (currentMode !== 'focused') { previousMode = currentMode; applyMode('focused'); }
        else { applyMode(previousMode); }
        closeMenu();
      }
    });

    var scrollThreshold = 10;
    var lastScrollTop = 0;
    tableWrap.addEventListener('scroll', function () {
      var st = tableWrap.scrollTop;
      if (st > scrollThreshold && lastScrollTop <= scrollThreshold && currentMode !== 'custom') {
        previousMode = currentMode;
        applyMode('focused');
      } else if (st === 0 && lastScrollTop > 0 && currentMode !== 'custom') {
        applyMode(previousMode);
      }
      lastScrollTop = st;
    });

    applyMode('default');
  })();
</script>

<script>
  function toggleNavCollapse() {
    document.body.classList.toggle('nav-collapsed');
  }

  // Stub for nav More button — full flyout not wired on this page
  function toggleMore(e) { if (e) e.stopPropagation(); }

  (function() {
    const NAV_LINKS = {
      'Home': 'Home.html',
      'Companies': 'Index.html',
      'Deals': 'Deals.html'
    };
    document.querySelectorAll('.side-nav .nav-item').forEach(el => {
      const lbl = el.querySelector('.nav-label');
      if (!lbl) return;
      const text = lbl.textContent.trim();
      if (NAV_LINKS[text]) {
        if (el.tagName === 'A') { el.setAttribute('href', NAV_LINKS[text]); }
        else { el.addEventListener('click', () => { window.location.href = NAV_LINKS[text]; }); el.style.cursor = 'pointer'; }
      }
    });

    document.querySelectorAll('.idx-tr').forEach(row => {
      row.style.cursor = 'pointer';
      row.addEventListener('click', (e) => {
        if (e.target.closest('button, a, input, select, textarea, .idx-cb')) return;
        const nameEl = row.querySelector('.idx-co-name-primary');
        const logoEl = row.querySelector('.idx-co-logo');
        const ownerNameEl = row.querySelector('.idx-owner span');
        const company = nameEl ? nameEl.textContent.trim() : '';
        const logoLetter = (logoEl && logoEl.textContent.trim()) || (company[0] || '').toUpperCase();
        const ownerName = ownerNameEl ? ownerNameEl.textContent.trim() : '';
        try {
          sessionStorage.setItem('prototypeDeal', JSON.stringify({
            kind: 'company',
            title: company,
            company: company,
            logoLetter: logoLetter,
            owner: { name: ownerName }
          }));
        } catch (err) {}
        window.location.href = 'Record.html';
      });
    });
  })();
</script>


</div><!-- /home-shell-content -->
</div><!-- /home-shell-row -->
</div><!-- /home-shell-root -->


<script>
(function(){
  // Highlight active sidebar icon and wire navigation by ordinal position.
  const SIDEBAR_TARGETS = {
    0: 'Home.html',
    2: 'Index.html',
    3: 'Deals.html'
  };
  const ACTIVE_INDEX_BY_PAGE = { home:0, companies:2, deals:3 };
  const root = document.querySelector('.home-shell-root');
  const page = (root && root.dataset.page) || 'home';
  const activeIdx = ACTIVE_INDEX_BY_PAGE[page];
  function findIcons(){
    const all = [...document.querySelectorAll('.home-shell-row > div:first-child button')];
    return all;
  }
  function wire(){
    const icons = findIcons();
    if (icons.length < 4) return false;
    icons.forEach((el, i) => {
      el.style.cursor = 'pointer';
      // active highlight: clear any inline highlight, then set on active
      try { el.style.background = (i === activeIdx) ? 'rgba(255,255,255,0.12)' : 'transparent'; } catch(e){}
      const target = SIDEBAR_TARGETS[i];
      if (target && el.dataset.protoWired !== '1') {
        el.dataset.protoWired = '1';
        el.addEventListener('click', (e) => { e.preventDefault(); e.stopPropagation(); window.location.href = target; }, true);
        el.addEventListener('mouseenter', () => {
          if (i !== activeIdx) { try { el.style.background = 'rgba(255,255,255,0.06)'; } catch(e){} }
        });
        el.addEventListener('mouseleave', () => {
          try { el.style.background = (i === activeIdx) ? 'rgba(255,255,255,0.12)' : 'transparent'; } catch(e){}
        });
      }
    });
    return true;
  }
  if (!wire()) {
    let tries = 0;
    const iv = setInterval(() => { if (wire() || ++tries > 20) clearInterval(iv); }, 100);
  }
})();
</script>


</body>
</html>
