<div class="home-shell-content">

  <!-- Main -->
  <div class="main-area">
    <div class="white-surface">
      <div class="idx-page">

        <!-- Page header row -->
        <div class="idx-breadcrumb-row">
          <div class="idx-title-wrap">
            <span class="idx-title">Companies</span>
          </div>
          <div class="idx-header-actions">
            <div class="idx-actions-menu-wrap">
              <button class="icon-btn" id="indexOverflowBtn" title="More actions" aria-haspopup="true" aria-expanded="false">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <circle cx="3" cy="7" r="1.2" fill="currentColor"/>
                  <circle cx="7" cy="7" r="1.2" fill="currentColor"/>
                  <circle cx="11" cy="7" r="1.2" fill="currentColor"/>
                </svg>
              </button>
              <div class="idx-actions-menu" id="indexOverflowMenu" role="menu" aria-hidden="true">
                <button class="idx-actions-menu-item active" role="menuitem" data-prospect-mode="carousel">
                  <span class="idx-actions-menu-item-bullet"></span>
                  <span>Carousel</span>
                </button>
                <button class="idx-actions-menu-item" role="menuitem" data-prospect-mode="view">
                  <span class="idx-actions-menu-item-bullet"></span>
                  <span>View</span>
                </button>
                <button class="idx-actions-menu-item" role="menuitem" data-prospect-mode="agent">
                  <span class="idx-actions-menu-item-bullet"></span>
                  <span>Data agent</span>
                </button>
              </div>
            </div>
            <div class="btn-split">
              <button class="btn-split-main">Add companies</button>
              <div class="btn-split-sep"></div>
              <button class="btn-split-menu">
                <svg width="10" height="10" viewBox="0 0 14 14" fill="none"><path d="M2.27 4.77a1 1 0 011.41 0L7 8.09l3.32-3.32a1 1 0 011.41 1.42L7.7 10.2a1 1 0 01-1.41 0L2.27 6.19a1 1 0 010-1.42z" fill="rgba(255,255,255,.8)"/></svg>
              </button>
            </div>
            <button class="icon-btn-plain" title="Calendar"><img src="assets/Calendar.svg" alt=""></button>
          </div>
        </div>

        <!-- Prospecting Agent cards -->
        <div class="prospect-strip">
          <div class="prospect-strip-header">
            <div class="prospect-strip-header-left">
              <span>Prospecting agent</span>
            </div>
            <div class="prospect-strip-header-actions">
              <div class="prospect-strip-header-btn" title="More actions">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="3" r="1.2" fill="currentColor"/><circle cx="7" cy="7" r="1.2" fill="currentColor"/><circle cx="7" cy="11" r="1.2" fill="currentColor"/></svg>
              </div>
              <div class="prospect-strip-header-btn" title="Collapse">
                <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M11.73 9.23a1 1 0 01-1.41 0L7 5.91 3.68 9.23a1 1 0 11-1.41-1.42L6.3 3.8a1 1 0 011.41 0l4.02 4.01a1 1 0 010 1.42z" fill="currentColor"/></svg>
              </div>
            </div>
          </div>
          <div class="prospect-cards">

            <div class="p-card">
              <div class="p-card-head">
                <div class="p-card-co">
                  <div class="p-card-logo co-h">H</div>
                  <span class="p-card-name">Horizonyte</span>
                </div>
              </div>
              <div class="p-card-desc">Hiring surged 28% in the last 90 days, signaling active growth.</div>
              <div class="p-card-tags">
                <span class="signal-tag signal-tag--intent">Visitor</span>
                <span class="signal-tag signal-tag--research">Research</span>
                <span class="signal-tag signal-tag--geo">Funding</span>
                <span class="signal-tag signal-tag--default">+2</span>
              </div>
            </div>

            <div class="p-card">
              <div class="p-card-head">
                <div class="p-card-co">
                  <div class="p-card-logo co-n">N</div>
                  <span class="p-card-name">Northwood Builders</span>
                </div>
              </div>
              <div class="p-card-desc">Website traffic spiked this month after launching new services.</div>
              <div class="p-card-tags">
                <span class="signal-tag signal-tag--intent">Visitor</span>
                <span class="signal-tag signal-tag--hiring">Web traffic</span>
                <span class="signal-tag signal-tag--launch">Product launch</span>
                <span class="signal-tag signal-tag--default">+1</span>
              </div>
            </div>

            <div class="p-card">
              <div class="p-card-head">
                <div class="p-card-co">
                  <div class="p-card-logo co-r">R</div>
                  <span class="p-card-name">RiverStone Builders</span>
                </div>
              </div>
              <div class="p-card-desc">Opened a new office this quarter, indicating expansion activity.</div>
              <div class="p-card-tags">
                <span class="signal-tag signal-tag--intent">Visitor</span>
                <span class="signal-tag signal-tag--expansion">Physical expansion</span>
              </div>
            </div>

            <div class="p-card">
              <div class="p-card-head">
                <div class="p-card-co">
                  <div class="p-card-logo co-o">S</div>
                  <span class="p-card-name">Southland Industries</span>
                </div>
              </div>
              <div class="p-card-desc">Electrical contractor. Services pricing page visited 3x this week.</div>
              <div class="p-card-tags">
                <span class="signal-tag signal-tag--intent">Visitor</span>
                <span class="signal-tag signal-tag--research">Research intent</span>
              </div>
            </div>

            <div class="p-card">
              <div class="p-card-head">
                <div class="p-card-co">
                  <div class="p-card-logo co-p">F</div>
                  <span class="p-card-name">Fairview Partners</span>
                </div>
              </div>
              <div class="p-card-desc">Engaged with content in the past 14 days — multiple stakeholders visited.</div>
              <div class="p-card-tags">
                <span class="signal-tag signal-tag--intent">Visitor</span>
                <span class="signal-tag signal-tag--research">Content engagement</span>
              </div>
            </div>

            <div class="p-card">
              <div class="p-card-head">
                <div class="p-card-co">
                  <div class="p-card-logo co-a">A</div>
                  <span class="p-card-name">Ashford Group</span>
                </div>
              </div>
              <div class="p-card-desc">Recently raised Series B. Leadership posted about CRM modernization.</div>
              <div class="p-card-tags">
                <span class="signal-tag signal-tag--geo">Funding</span>
                <span class="signal-tag signal-tag--hiring">Hiring surge</span>
                <span class="signal-tag signal-tag--research">Research intent</span>
              </div>
            </div>

          </div>
        </div>

        <!-- Tabs + toolbar -->
        <div class="idx-toolbar">
          <div class="idx-tabs">
            <button class="idx-tab active" data-view="default">
              <svg class="idx-tab-icon" width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="1.5" y="1.5" width="4" height="11" rx="1" stroke="currentColor" stroke-width="1.2" fill="none"/><rect x="8.5" y="1.5" width="4" height="7" rx="1" stroke="currentColor" stroke-width="1.2" fill="none"/></svg>
              All companies
            </button>
            <button class="idx-tab" data-view="default">
              <svg class="idx-tab-icon" width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="1.5" y="1.5" width="4" height="11" rx="1" stroke="currentColor" stroke-width="1.2" fill="none"/><rect x="8.5" y="1.5" width="4" height="7" rx="1" stroke="currentColor" stroke-width="1.2" fill="none"/></svg>
              My companies
            </button>
            <button class="idx-tab idx-tab--recommended" data-view="recommended">
              <svg class="idx-tab-icon" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1.5l1.4 3.6 3.6.5-2.8 2.5.8 3.4L7 9.7l-3 1.8.8-3.4L2 5.6l3.6-.5L7 1.5z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" fill="none"/></svg>
              Recommended
            </button>
            <button class="idx-tab-add" title="Add view">+</button>
          </div>
          <div class="idx-toolbar-right">
            <button class="idx-icon-btn" title="Search"><img src="assets/Search.svg" alt=""></button>
            <button class="idx-icon-btn" title="Filter"><img src="assets/Filter.svg" alt=""></button>
            <button class="idx-icon-btn" title="Sort"><img src="assets/Sort.svg" alt=""></button>
            <button class="idx-icon-btn" title="Settings"><img src="assets/Settings.svg" alt=""></button>
            <div class="idx-toolbar-sep"></div>
            <div class="idx-view-toggle">
              <button class="idx-view-btn" title="Board view" data-view-target="Deals.html"><img src="assets/Board.svg" alt=""></button>
              <button class="idx-view-btn active" title="Table view" data-view-target="Index.html"><img src="assets/table.svg" alt=""></button>
            </div>
            <div class="idx-toolbar-sep" id="layoutSep"></div>
            <div class="layout-control" id="layoutControl">
              <button class="idx-icon-btn layout-btn" id="layoutBtn" title="Layout" aria-haspopup="true" aria-expanded="false">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <rect x="1.5" y="1.5" width="5.5" height="13" rx="1" stroke="currentColor" stroke-width="1.2" fill="none"/>
                  <rect x="9" y="1.5" width="5.5" height="6" rx="1" stroke="currentColor" stroke-width="1.2" fill="none"/>
                  <rect x="9" y="9.5" width="5.5" height="5" rx="1" stroke="currentColor" stroke-width="1.2" fill="none"/>
                </svg>
              </button>
              <div class="layout-menu" id="layoutMenu" role="menu" aria-hidden="true">
                <button class="layout-menu-item" id="layoutOptDefault" role="menuitem" data-mode="default">
                  <span class="layout-menu-item-label">Default</span>
                  <span class="layout-menu-item-shortcut"></span>
                </button>
                <button class="layout-menu-item" id="layoutOptFocused" role="menuitem" data-mode="focused">
                  <span class="layout-menu-item-label">Focused</span>
                  <span class="layout-menu-item-shortcut">F</span>
                </button>
                <button class="layout-menu-item" id="layoutOptCustom" role="menuitem" data-mode="custom">
                  <span class="layout-menu-item-label">Custom</span>
                  <span class="layout-menu-item-shortcut"></span>
                </button>
                <div class="layout-custom-panel" id="layoutCustomPanel">
                  <div class="layout-toggle-row">
                    <span class="layout-toggle-label">Page header</span>
                    <button class="layout-toggle-switch" role="switch" aria-checked="true" data-toggle="pageHeader">
                      <span class="layout-toggle-thumb"></span>
                    </button>
                  </div>
                  <div class="layout-toggle-row layout-toggle-row--disabled">
                    <span class="layout-toggle-label">Quick filters</span>
                    <button class="layout-toggle-switch layout-toggle-switch--disabled" disabled role="switch" aria-checked="false" aria-disabled="true">
                      <span class="layout-toggle-thumb"></span>
                    </button>
                  </div>
                  <div class="layout-toggle-row layout-toggle-row--disabled">
                    <span class="layout-toggle-label">Center widget</span>
                    <button class="layout-toggle-switch layout-toggle-switch--disabled" disabled role="switch" aria-checked="false" aria-disabled="true">
                      <span class="layout-toggle-thumb"></span>
                    </button>
                  </div>
                  <div class="layout-toggle-row layout-toggle-row--disabled">
                    <span class="layout-toggle-label">Footer widget</span>
                    <button class="layout-toggle-switch layout-toggle-switch--disabled" disabled role="switch" aria-checked="false" aria-disabled="true">
                      <span class="layout-toggle-thumb"></span>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

